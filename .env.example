# [ candy-e ] — Variables d'environnement backend (Clever Cloud)
# Copier en .env (déjà ignoré par git) et renseigner les vraies valeurs.
# Ne jamais committer de vraies valeurs dans ce fichier .example.

# Chaîne de connexion PostgreSQL (Clever Cloud injecte POSTGRESQL_ADDON_URI
# automatiquement sur l'addon ; DATABASE_URL sert de repli pour du dev local)
POSTGRESQL_ADDON_URI=postgresql://user:password@host:port/dbname

PORT=8080
NODE_ENV=development

# Middleware JWT minimal (pont temporaire avant Pro Santé Connect, Phase 1)
# Générer une vraie valeur avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Base URL du frontend statique, utilisée pour construire le lien de
# réinitialisation de mot de passe (routes/auth.js:/forgot-password).
# ⚠️ Aucun service d'envoi d'email n'est branché — le lien est journalisé
# côté serveur en attendant un choix de fournisseur SMTP.
# URL publique de l'application en production (domaine Clever Cloud, ex. https://xxx.cleverapps.io).
# Utilisée par le middleware CORS pour restreindre les origines autorisées en production.
# En développement (NODE_ENV !== 'production'), toutes les origines sont acceptées.
FRONTEND_URL=https://xxx.cleverapps.io

# Placeholders pour les futurs chantiers Ségur (Phase 1 — non utilisés tant
# que ces intégrations ne sont pas développées)
PSC_CLIENT_ID=
PSC_CLIENT_SECRET=

# Client INSi (services/insi/client.js), environnement de test CNDA.
# INSI_CERT_PATH : chemin vers le bundle PKCS#12 (.p12/.pfx) du certificat
# logiciel CNDA — jamais commité, jamais en dur dans le code.
INSI_CERT_PATH=
INSI_CERT_PASSWORD=
INSI_ENDPOINT=
# Identification LPS (Logiciel de Poste de Santé) transmise dans chaque
# enveloppe SOAP — valeurs délivrées lors du référencement/homologation.
LPS_NOM=
LPS_VERSION=
LPS_NIL=

# Module RGPD (services/rgpd/) — purge automatique + notification DPO.
# DPO_EMAIL : lu par services/rgpd/notifications/dpo.notify.js, mais aucun
# envoi réel n'est branché (même limitation que FRONTEND_URL ci-dessus,
# pas de SMTP configuré) — la notification est journalisée en attendant.
DPO_EMAIL=dpo@safe-digitalisation.fr
# PURGE_JOB_ENABLED=false désactive le scheduler (services/rgpd/purge/) —
# utile en développement pour ne pas purger une base de test au démarrage.
PURGE_JOB_ENABLED=true

# Service d'envoi d'emails (services/email/) — routage automatique selon le
# type de message (cf. services/email/emailTypes.js) : notification_ps,
# rgpd_acces et rgpd_violation partent obligatoirement par le facteur
# MSSanté (contrainte ANS/PSC EXI EDC PSC 102-6, RGPD Art. 33) ; les autres
# types partent par le facteur SMTP classique.

# Facteur classique — services/email/smtpClassic.js (MailPace / Clever Cloud).
# ⚠️ Non câblé par défaut : emailRouter.js pointe sur smtpBrevo.js (cf.
# ci-dessous). Conservé au cas où Brevo serait remplacé plus tard — il suffit
# alors de changer l'import dans emailRouter.js.
SMTP_CLASSIC_HOST=smtp.mailpace.com
SMTP_CLASSIC_PORT=465
SMTP_CLASSIC_USER=your_mailpace_api_key
SMTP_CLASSIC_PASS=your_mailpace_api_key
SMTP_CLASSIC_FROM=noreply@candy-e.fr
SMTP_CLASSIC_TLS=true

# Facteur classique actif — services/email/smtpBrevo.js (Brevo). Ne reçoit
# jamais les types listés dans MSSANTE_TYPES (cf. emailTypes.js) : le routage
# par emailRouter.js garantit qu'aucune donnée résident/santé ne transite par
# Brevo — seul le canal MSSanté ci-dessous en est autorisé.
# Mode SMTP (dev/staging) — Brevo > SMTP & API > SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
# Mode API REST (production, NODE_ENV=production) — Brevo > SMTP & API > API Keys
BREVO_API_KEY=
# Expéditeur affiché (commun aux deux modes)
EMAIL_FROM_ADDRESS=noreply@candy-e.fr
EMAIL_FROM_NAME=C@NDY-e

# Facteur MSSanté (paramètres fictifs — à remplacer par l'opérateur MSSanté
# réel une fois référencé). Absent au démarrage => warning console, pas
# d'erreur fatale (le canal classique reste opérationnel).
SMTP_MSSANTE_HOST=smtp.operateur-mssante.fictif
SMTP_MSSANTE_PORT=587
SMTP_MSSANTE_USER=candy-e@structure.mssante.fr
SMTP_MSSANTE_PASS=secret_mssante
SMTP_MSSANTE_FROM=candy-e@structure.mssante.fr
SMTP_MSSANTE_TLS=true
SMTP_MSSANTE_STARTTLS=true
